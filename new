<!DOCTYPE html>
<html>

<head>
    <title>Registration Form</title>
</head>

<body>

    <h2>Registration Form</h2>

    <form onsubmit="showMessage(event)">
        Email:
        <input type="email" pattern="[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+\.com" title="Email must end with .com" required>

        <br><br> Password:
        <input type="password" required>

        <br><br> Mobile Number:
        <input type="text" required>

        <br><br> Gender:
        <input type="radio" name="gender" required> Male
        <input type="radio" name="gender"> Female

        <br><br> City:
        <select required>
            <option value="">Select City</option>
            <option>Pune</option>
            <option>Mumbai</option>
            <option>Nasik</option>
            <option>Bangalore</option>
        </select>

        <br><br>
        <input type="submit" value="Login">
    </form>

    <h3 id="message" style="color: green;"></h3>

    <script>
        function showMessage(event) {
            event.preventDefault();
            document.getElementById("message").innerHTML = "Login successfully!";
        }
    </script>

</body>

</html>
